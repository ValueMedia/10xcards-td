---
import Layout from "@/layouts/Layout.astro";
import { listSetsWithFlashcardCounts } from "@/lib/services/sets";
import { getLearningStats } from "@/lib/services/stats";
import type { LearningStats } from "@/types";
import SetDashboard from "@/components/sets/SetDashboard";

const { user, supabase } = Astro.locals;
let sets: (import("@/types").FlashcardSet & { flashcard_count: number })[] = [];
let dbError: string | null = null;
let stats: LearningStats = { dailyMinutes: [], recentSets: [] };

if (user && supabase) {
  const [setsResult, statsResult] = await Promise.all([
    listSetsWithFlashcardCounts(supabase, user.id),
    getLearningStats(supabase, user.id),
  ]);
  sets = setsResult.data ?? [];
  dbError = setsResult.error;
  stats = statsResult.data ?? { dailyMinutes: [], recentSets: [] };
}
---

<Layout title="Dashboard">
  {
    dbError ? (
      <div class="bg-cosmic flex min-h-screen items-center justify-center p-4 text-white">
        <p class="text-red-400">Failed to load sets. Please try again later.</p>
      </div>
    ) : (
      <SetDashboard initialSets={JSON.stringify(sets)} initialStats={JSON.stringify(stats)} client:load />
    )
  }
</Layout>
