---
import Layout from "@/layouts/Layout.astro";
import { getTranslations } from "@/lib/i18n/ui";

const isAutoConfirmed = import.meta.env.DEV;
const locale = Astro.locals.locale;
const t = getTranslations(locale);

const heading = isAutoConfirmed ? t("auth.confirmEmail.titleDev") : t("auth.confirmEmail.titleProd");
const description = isAutoConfirmed ? t("auth.confirmEmail.descDev") : t("auth.confirmEmail.descProd");
const linkText = isAutoConfirmed ? t("auth.confirmEmail.goToSignIn") : t("auth.confirmEmail.backToSignIn");
const emoji = isAutoConfirmed ? "✅" : "📧";
---

<Layout title={heading} locale={locale}>
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <div class="mb-4 text-5xl">{emoji}</div>
      <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        {heading}
      </h1>
      <p class="mb-6 text-blue-100/80">{description}</p>
      <a href="/auth/signin" class="text-sm text-purple-300 hover:underline">
        {linkText}
      </a>
    </div>
  </div>
</Layout>
