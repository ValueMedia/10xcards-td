---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { getSetByIdForUser } from "@/lib/services/sets";
import ReviewSession from "@/components/review/ReviewSession";
import type { SupportedLocale } from "@/lib/i18n/constants";

const { id } = Astro.params;
const { user, supabase, locale } = Astro.locals;

let setName = "";
let found = false;

if (user && supabase && id) {
  const { data, error } = await getSetByIdForUser(supabase, user.id, id);
  if (data && !error) {
    setName = data.name;
    found = true;
  }
}

if (!found || !id) {
  Astro.response.status = 302;
  Astro.response.headers.set("Location", id ? `/sets/${id}` : "/dashboard");
  return;
}
---

<Layout title={`Review — ${setName}`}>
  <ReviewSession client:only="react" setId={id} setName={setName} locale={locale as SupportedLocale} />
</Layout>
