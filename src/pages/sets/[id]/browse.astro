---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { getSetWithFlashcards } from "@/lib/services/sets";
import FlashcardBrowseView from "@/components/sets/FlashcardBrowseView";
import type { SupportedLocale } from "@/lib/i18n/constants";
import type { Flashcard } from "@/types";

const { id } = Astro.params;
const { user, supabase, locale } = Astro.locals;

let setName = "";
let flashcards: Flashcard[] = [];
let found = false;

if (user && supabase && id) {
  const { data, error } = await getSetWithFlashcards(supabase, user.id, id);
  if (data && !error && data.flashcards.length > 0) {
    setName = data.set.name;
    flashcards = data.flashcards;
    found = true;
  }
}

if (!found || !id) {
  Astro.response.status = 302;
  Astro.response.headers.set("Location", id ? `/sets/${id}` : "/dashboard");
  return;
}
---

<Layout title={`Browse — ${setName}`}>
  <FlashcardBrowseView
    client:only="react"
    setId={id}
    setName={setName}
    flashcards={flashcards}
    locale={locale as SupportedLocale}
  />
</Layout>
