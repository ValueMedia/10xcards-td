---
import Layout from "@/layouts/Layout.astro";
import GenerateFlashcardsPage from "@/components/ai/GenerateFlashcardsPage";
import { getSetByIdForUser } from "@/lib/services/sets";

export const prerender = false;

const { user, supabase } = Astro.locals;
const setId = Astro.url.searchParams.get("setId");

let setName: string | null = null;
let isOwner = false;

if (user && supabase && setId) {
  const { data, error } = await getSetByIdForUser(supabase, user.id, setId);
  if (data && !error) {
    setName = data.name;
    isOwner = true;
  }
}

if (!isOwner || !setId) {
  Astro.response.status = 302;
  Astro.response.headers.set("Location", "/dashboard");
  return;
}
---

<Layout title={`Generate flashcards · ${setName}`}>
  <GenerateFlashcardsPage setId={setId} setName={setName} client:load />
</Layout>
