---
import Layout from "@/layouts/Layout.astro";
import { getUserPrompt } from "@/lib/services/user-settings";
import { SettingsPage } from "@/components/settings/SettingsPage";
import { I18nProvider } from "@/components/I18nProvider";

const { user, supabase, locale } = Astro.locals;

if (!user || !supabase) {
  return Astro.redirect("/auth/signin");
}

const { data: promptData } = await getUserPrompt(supabase, user.id);

const initialPrompt = promptData?.prompt ?? null;
const initialFlashcardCount = promptData?.flashcard_count ?? null;
---

<Layout title="Settings" locale={locale}>
  <I18nProvider locale={locale} client:load>
    <SettingsPage
      email={user.email ?? ""}
      initialPrompt={initialPrompt}
      initialFlashcardCount={initialFlashcardCount}
    />
  </I18nProvider>
</Layout>