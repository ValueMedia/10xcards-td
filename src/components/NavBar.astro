---
const { user } = Astro.locals;
---

{
  user && (
    <nav class="sticky top-0 z-50 border-b border-white/10 bg-black/20 backdrop-blur-xl">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-6">
          <a
            href="/"
            class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-lg font-bold text-transparent"
          >
            10xCards
          </a>
          <a href="/dashboard" class="text-sm text-blue-100/60 transition-colors hover:text-white">
            Dashboard
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-blue-100/40">{user.email ?? "Signed in"}</span>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-md border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-blue-100/60 transition-colors hover:bg-white/10 hover:text-white"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>
    </nav>
  )
}
