{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "npm *": "allow",
      "npx *": "allow",
      "node *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git stash *": "allow",
      "curl *": "ask",
      "wget *": "ask",
      "git push *": "ask",
      "rm -rf *": "deny",
      "*": "ask"
    },
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow"
  }
}
